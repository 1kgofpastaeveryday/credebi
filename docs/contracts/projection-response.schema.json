{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://credebi.com/schemas/projection-response.schema.json",
  "title": "ProjectionResponse",
  "description": "Projection API response contract aligned with calculateProjection output (Projection interface) plus compatibility aliases.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "status",
    "data_as_of",
    "is_stale",
    "stale_sources",
    "timezone",
    "horizon_days",
    "currency",
    "aggregate_balance",
    "aggregate_timeline",
    "aggregate_balance_bars",
    "account_projections",
    "balance_bars",
    "charge_coverages",
    "danger_zones",
    "summary"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Server-side generation timestamp."
    },
    "status": {
      "$ref": "#/$defs/projectionStatus"
    },
    "data_as_of": {
      "type": "string",
      "format": "date-time",
      "description": "Oldest upstream source update timestamp used by this projection."
    },
    "is_stale": {
      "type": "boolean",
      "description": "True when one or more projection inputs are stale."
    },
    "stale_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Stale-source identifiers (e.g. bank_balance:楽天銀行, income_account_unknown)."
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "horizon_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 120
    },
    "currency": {
      "type": "string",
      "enum": [
        "JPY"
      ]
    },
    "aggregate_balance": {
      "type": "number",
      "description": "Current combined balance across all bank accounts."
    },
    "aggregate_timeline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/timelineEvent"
      }
    },
    "aggregate_balance_bars": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/balanceBar"
      }
    },
    "account_projections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/accountProjection"
      }
    },
    "balance_bars": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/balanceBar"
      },
      "description": "Compatibility alias for aggregate_balance_bars used by legacy UI contracts."
    },
    "charge_coverages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/cardChargeCoverage"
      }
    },
    "danger_zones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dangerZone"
      }
    },
    "summary": {
      "$ref": "#/$defs/projectionSummary"
    }
  },
  "$defs": {
    "projectionStatus": {
      "type": "string",
      "enum": [
        "SETUP_REQUIRED",
        "SAFE",
        "WARNING",
        "CRITICAL"
      ]
    },
    "timelineEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "date",
        "type",
        "bank_account_id",
        "description",
        "amount",
        "running_balance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "type": {
          "type": "string",
          "enum": [
            "income",
            "card_charge",
            "fixed_cost",
            "variable_cost",
            "estimated_card_spend"
          ]
        },
        "account_id": {
          "type": "string",
          "minLength": 1,
          "description": "Optional related account id (e.g. credit card id for card_charge)."
        },
        "bank_account_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "amount": {
          "type": "number",
          "description": "Signed amount in JPY. Positive=inflow, negative=outflow."
        },
        "running_balance": {
          "type": "number",
          "description": "Per-account running balance after this event."
        }
      }
    },
    "dangerZone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "shortfall",
        "cause",
        "suggestion"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "shortfall": {
          "type": "number"
        },
        "cause": {
          "type": "string",
          "minLength": 1
        },
        "suggestion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "balanceBar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "phase",
        "start_balance",
        "end_balance",
        "inflow",
        "outflow",
        "below_zero",
        "trigger_event_ids"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "phase": {
          "type": "string",
          "enum": [
            "actual",
            "forecast"
          ]
        },
        "start_balance": {
          "type": "number"
        },
        "end_balance": {
          "type": "number"
        },
        "inflow": {
          "type": "number",
          "minimum": 0
        },
        "outflow": {
          "type": "number",
          "minimum": 0
        },
        "below_zero": {
          "type": "boolean"
        },
        "trigger_event_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "accountProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_id",
        "account_name",
        "current_balance",
        "timeline",
        "balance_bars",
        "danger_zones",
        "is_safe"
      ],
      "properties": {
        "account_id": {
          "type": "string",
          "minLength": 1
        },
        "account_name": {
          "type": "string",
          "minLength": 1
        },
        "current_balance": {
          "type": "number"
        },
        "timeline": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/timelineEvent"
          }
        },
        "balance_bars": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/balanceBar"
          }
        },
        "danger_zones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dangerZone"
          }
        },
        "is_safe": {
          "type": "boolean"
        }
      }
    },
    "cardChargeCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "card_name",
        "billing_date",
        "charge_amount",
        "balance_before",
        "balance_after",
        "shortfall",
        "is_funded",
        "utilization"
      ],
      "properties": {
        "card_id": {
          "type": "string",
          "minLength": 1
        },
        "card_name": {
          "type": "string",
          "minLength": 1
        },
        "billing_date": {
          "type": "string",
          "format": "date"
        },
        "charge_amount": {
          "type": "number",
          "minimum": 0
        },
        "balance_before": {
          "type": "number"
        },
        "balance_after": {
          "type": "number"
        },
        "shortfall": {
          "type": "number",
          "minimum": 0
        },
        "is_funded": {
          "type": "boolean"
        },
        "utilization": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "projectionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safety_status",
        "projected_end_balance",
        "first_deficit_date",
        "first_deficit_shortfall",
        "funded_charges",
        "unfunded_charges",
        "min_projected_balance",
        "pre_income_balance"
      ],
      "properties": {
        "safety_status": {
          "$ref": "#/$defs/projectionStatus"
        },
        "projected_end_balance": {
          "type": "number"
        },
        "first_deficit_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "first_deficit_shortfall": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "funded_charges": {
          "type": "integer",
          "minimum": 0
        },
        "unfunded_charges": {
          "type": "integer",
          "minimum": 0
        },
        "min_projected_balance": {
          "type": "number"
        },
        "pre_income_balance": {
          "type": [
            "number",
            "null"
          ],
          "description": "Projected balance the day before the next income event. Null if no income is scheduled."
        }
      }
    }
  },
  "examples": [
    {
      "generated_at": "2026-03-11T22:00:00+09:00",
      "status": "WARNING",
      "data_as_of": "2026-03-11T21:30:00+09:00",
      "is_stale": false,
      "stale_sources": [],
      "timezone": "Asia/Tokyo",
      "horizon_days": 60,
      "currency": "JPY",
      "aggregate_balance": 5600,
      "aggregate_timeline": [
        {
          "id": "ev_lifecard_20260327",
          "date": "2026-03-27",
          "type": "card_charge",
          "account_id": "card_lifecard",
          "bank_account_id": "bank_smbc_main",
          "description": "ライフカード引き落とし",
          "amount": -12800,
          "running_balance": -7200
        }
      ],
      "aggregate_balance_bars": [
        {
          "date": "2026-03-27",
          "phase": "forecast",
          "start_balance": 5600,
          "end_balance": -7200,
          "inflow": 0,
          "outflow": 12800,
          "below_zero": true,
          "trigger_event_ids": [
            "ev_lifecard_20260327"
          ]
        }
      ],
      "account_projections": [
        {
          "account_id": "bank_smbc_main",
          "account_name": "三井住友銀行",
          "current_balance": 5600,
          "timeline": [
            {
              "id": "ev_lifecard_20260327",
              "date": "2026-03-27",
              "type": "card_charge",
              "account_id": "card_lifecard",
              "bank_account_id": "bank_smbc_main",
              "description": "ライフカード引き落とし",
              "amount": -12800,
              "running_balance": -7200
            }
          ],
          "balance_bars": [
            {
              "date": "2026-03-27",
              "phase": "forecast",
              "start_balance": 5600,
              "end_balance": -7200,
              "inflow": 0,
              "outflow": 12800,
              "below_zero": true,
              "trigger_event_ids": [
                "ev_lifecard_20260327"
              ]
            }
          ],
          "danger_zones": [
            {
              "date": "2026-03-27",
              "shortfall": 7200,
              "cause": "ライフカード引き落とし",
              "suggestion": "3/27までに口座へ入金してください"
            }
          ],
          "is_safe": false
        }
      ],
      "balance_bars": [
        {
          "date": "2026-03-27",
          "phase": "forecast",
          "start_balance": 5600,
          "end_balance": -7200,
          "inflow": 0,
          "outflow": 12800,
          "below_zero": true,
          "trigger_event_ids": [
            "ev_lifecard_20260327"
          ]
        }
      ],
      "charge_coverages": [
        {
          "card_id": "card_lifecard",
          "card_name": "ライフカード",
          "billing_date": "2026-03-27",
          "charge_amount": 12800,
          "balance_before": 5600,
          "balance_after": -7200,
          "shortfall": 7200,
          "is_funded": false,
          "utilization": null
        }
      ],
      "danger_zones": [
        {
          "date": "2026-03-27",
          "shortfall": 7200,
          "cause": "ライフカード引き落とし",
          "suggestion": "3/27までに口座へ入金してください"
        }
      ],
      "summary": {
        "safety_status": "WARNING",
        "projected_end_balance": -7200,
        "first_deficit_date": "2026-03-27",
        "first_deficit_shortfall": 7200,
        "funded_charges": 0,
        "unfunded_charges": 1,
        "min_projected_balance": -7200,
        "pre_income_balance": -7200
      }
    }
  ]
}
