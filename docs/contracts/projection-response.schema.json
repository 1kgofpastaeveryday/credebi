{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://credebi.com/schemas/projection-response.schema.json",
  "title": "ProjectionResponse",
  "description": "Projection API response contract for balance bars and charge coverages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "data_as_of",
    "is_stale",
    "timezone",
    "horizon_days",
    "currency",
    "balance_bars",
    "charge_coverages",
    "summary"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Server-side generation timestamp."
    },
    "data_as_of": {
      "type": "string",
      "format": "date-time",
      "description": "DT-033: Timestamp of the most recent upstream data (MIN of email last_synced_at, income last sync, etc). If significantly older than generated_at, the projection is based on stale data."
    },
    "is_stale": {
      "type": "boolean",
      "description": "DT-033: true if now() - data_as_of > staleness_threshold. UI must show degraded display when true."
    },
    "stale_sources": {
      "type": "array",
      "items": { "type": "string" },
      "description": "DT-033: List of upstream sources that are stale (e.g. ['gmail:vpass', 'freee']). Empty if is_stale=false."
    },
    "timezone": {
      "type": "string",
      "minLength": 1,
      "description": "Applied timezone for date bucketing."
    },
    "horizon_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 120,
      "description": "Forecast horizon in days."
    },
    "currency": {
      "type": "string",
      "enum": [
        "JPY"
      ]
    },
    "balance_bars": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/balanceBar"
      }
    },
    "charge_coverages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/cardChargeCoverage"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "balanceBar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "phase",
        "start_balance",
        "end_balance",
        "inflow",
        "outflow",
        "below_zero",
        "trigger_event_ids"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "phase": {
          "type": "string",
          "enum": [
            "actual",
            "forecast"
          ]
        },
        "start_balance": {
          "type": "integer",
          "description": "Balance at start of day."
        },
        "end_balance": {
          "type": "integer",
          "description": "Balance at end of day."
        },
        "inflow": {
          "type": "integer",
          "minimum": 0,
          "description": "Total inflow for the day."
        },
        "outflow": {
          "type": "integer",
          "minimum": 0,
          "description": "Total outflow for the day (absolute value)."
        },
        "below_zero": {
          "type": "boolean",
          "description": "True when end_balance < 0."
        },
        "trigger_event_ids": {
          "type": "array",
          "description": "Event IDs that pushed the balance below zero on this day.",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "daily_breakdown": {
          "$ref": "#/$defs/dailyBreakdown"
        }
      }
    },
    "cashflowItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "amount"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "amount": {
          "type": "integer",
          "minimum": 0,
          "description": "Absolute amount in JPY."
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dailyBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "income_items",
        "spend_items"
      ],
      "properties": {
        "income_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cashflowItem"
          }
        },
        "spend_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cashflowItem"
          }
        }
      }
    },
    "cardChargeCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "card_name",
        "billing_date",
        "charge_amount",
        "balance_before",
        "balance_after",
        "shortfall",
        "is_funded"
      ],
      "properties": {
        "card_id": {
          "type": "string",
          "format": "uuid"
        },
        "card_name": {
          "type": "string",
          "minLength": 1
        },
        "billing_date": {
          "type": "string",
          "format": "date"
        },
        "charge_amount": {
          "type": "integer",
          "minimum": 0
        },
        "balance_before": {
          "type": "integer"
        },
        "balance_after": {
          "type": "integer"
        },
        "shortfall": {
          "type": "integer",
          "minimum": 0
        },
        "is_funded": {
          "type": "boolean"
        },
        "cause_event_id": {
          "type": "string",
          "minLength": 1,
          "description": "Optional timeline event ID for UI deep-link."
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safety_status",
        "projected_end_balance",
        "first_deficit_date",
        "first_deficit_shortfall",
        "funded_charges",
        "unfunded_charges"
      ],
      "properties": {
        "safety_status": {
          "type": "string",
          "enum": [
            "safe",
            "warning"
          ],
          "description": "Binary status for low-cognitive UI. 'warning' means balance dips below zero at least once."
        },
        "projected_end_balance": {
          "type": "integer"
        },
        "first_deficit_date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "null"
            }
          ]
        },
        "first_deficit_shortfall": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "funded_charges": {
          "type": "integer",
          "minimum": 0
        },
        "unfunded_charges": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "examples": [
    {
      "generated_at": "2026-02-21T13:45:00+09:00",
      "timezone": "Asia/Tokyo",
      "horizon_days": 60,
      "currency": "JPY",
      "balance_bars": [
        {
          "date": "2026-03-27",
          "phase": "forecast",
          "start_balance": 5600,
          "end_balance": -7200,
          "inflow": 0,
          "outflow": 12800,
          "below_zero": true,
          "trigger_event_ids": [
            "ev_lifecard_20260327"
          ],
          "daily_breakdown": {
            "income_items": [],
            "spend_items": [
              {
                "id": "tx_netflix_20260327",
                "label": "Netflix fee",
                "amount": 1490
              },
              {
                "id": "tx_food_20260327",
                "label": "Lunch at Ueno",
                "amount": 980
              }
            ]
          }
        }
      ],
      "charge_coverages": [
        {
          "card_id": "5fe65448-2860-4f46-b6d6-2f3f0c2d7755",
          "card_name": "ライフカード",
          "billing_date": "2026-03-27",
          "charge_amount": 12800,
          "balance_before": 5600,
          "balance_after": -7200,
          "shortfall": 7200,
          "is_funded": false,
          "cause_event_id": "ev_lifecard_20260327"
        }
      ],
      "summary": {
        "safety_status": "warning",
        "projected_end_balance": 471130,
        "first_deficit_date": "2026-03-27",
        "first_deficit_shortfall": 7200,
        "funded_charges": 2,
        "unfunded_charges": 1
      }
    }
  ]
}
